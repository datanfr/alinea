<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Alinéa{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('images/logo.svg') }}">
        <style>
            @font-face {
                font-family: 'Poppins';
                font-style: normal;
                font-weight: 500;
                font-display: swap;
                src: url('{{ asset('images/Poppins-Medium.ttf') }}') format('truetype');
            }
            @font-face {
                font-family: 'Poppins';
                font-style: normal;
                font-weight: 700;
                font-display: swap;
                src: url('{{ asset('images/Poppins-Bold.ttf') }}') format('truetype');
            }
            @font-face {
                font-family: 'Poppins';
                font-style: italic;
                font-weight: 700;
                font-display: swap;
                src: url('{{ asset('images/Poppins-BoldItalic.ttf') }}') format('truetype');
            }
            @font-face {
                font-family: 'Poppins';
                font-style: normal;
                font-weight: 900;
                font-display: swap;
                src: url('{{ asset('images/Poppins-Black.ttf') }}') format('truetype');
            }
            :root {
                --bleu: #301639;
                --bleu-hover: #663079;
                --rouge: #e4572c;
                --encre: #1e1e1e;
                --gris: #666;
                --fond: #f6f6f6;
                --bordure: #ddd;
                --police: 'Poppins', system-ui, -apple-system, Segoe UI, sans-serif;
            }
            * { box-sizing: border-box; }
            body {
                margin: 0;
                font-family: var(--police);
                color: var(--encre);
                background: var(--fond);
                line-height: 1.6;
            }
            header.site {
                background: #fff;
                border-bottom: 3px solid var(--bleu);
                padding: 1rem 1.5rem;
            }
            header.site .inner {
                max-width: 60rem;
                margin: 0 auto;
                display: flex;
                align-items: center;
                gap: 1rem;
            }
            header.site img { height: 3rem; }
            header.site .baseline {
                font-family: var(--police);
                font-size: .85rem;
                color: var(--gris);
            }
            main {
                max-width: 60rem;
                margin: 2rem auto;
                padding: 0 1.5rem;
            }
            a { color: var(--bleu); }
            a:hover { color: var(--bleu-hover); }
            {% block styles %}{% endblock %}
        </style>
    </head>
    <body>
        <header class="site">
            <div class="inner">
                <a href="{{ path('loi_index') }}"><img src="{{ asset('images/logo.svg') }}" alt="Alinéa"></a>
                <span class="baseline">Reconstituer l'intention du législateur</span>
            </div>
        </header>
        <main>
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
