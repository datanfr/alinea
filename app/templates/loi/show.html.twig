{% extends 'base.html.twig' %}

{% block title %}{{ loi.num ? 'Loi n° ' ~ loi.num : loi.titre }} — Alinéa{% endblock %}

{% macro carteAmendement(a) %}
    {% set libellesCategorie = {
        coordination: 'Coordination', redactionnel: 'Rédactionnel',
        simplification: 'Simplification', correction: 'Correction',
        precision: 'Précision', consequence: 'Conséquence',
        coherence: 'Cohérence', fond: 'Fond',
    } %}
    <article class="carte-amendement classe-{{ a.classe }}"
             {% if a.uid is defined %}id="amdt-{{ a.uid }}"{% endif %}
             data-sort="{{ a.classe }}"
             data-impact="{{ a.scoreImpactIa ?? -1 }}"
             data-categorie="{{ a.categorieIa ?? '' }}"
             data-recherche="{{ [a.numero, a.auteur, a.groupe, a.division, a.resumeIa, a.intentionIa, (a.categorieIa ? libellesCategorie[a.categorieIa])]|join(' ')|lower }}">
        <div class="carte-tete">
            <span class="badge {{ a.classe }}">{{ a.statut }}</span>
            <span class="carte-num">n° {{ a.numero }}</span>
        </div>
        <p class="carte-meta">
            {{ a.auteur }}{% if a.groupe %} ({{ a.groupe }}){% endif %}
            {%- if a.division %} · {{ a.division }}{% endif %}
        </p>
        {# resumeIa null = pas encore analysé ; vide = analysé, purement technique. #}
        {% if a.resumeIa is not null %}
            {% if a.resumeIa %}
                <p class="carte-resume">{{ a.resumeIa }}</p>
            {% else %}
                <p class="carte-resume vide">Amendement technique, sans changement de fond.</p>
            {% endif %}
            {% if a.intentionIa %}
                <p class="carte-intention"><strong>Intention :</strong> {{ a.intentionIa }}</p>
            {% endif %}
            {% if a.categorieIa or a.scoreImpactIa is not null %}
                <div class="carte-badges">
                    {% if a.categorieIa %}<span class="badge-ia">{{ libellesCategorie[a.categorieIa] ?? a.categorieIa }}</span>{% endif %}
                    {% if a.scoreImpactIa is not null %}<span class="badge-ia">Impact {{ a.scoreImpactIa }}/100</span>{% endif %}
                </div>
            {% endif %}
        {% else %}
            <p class="carte-resume vide">Analyse en cours…</p>
        {% endif %}
        <a class="carte-lien" href="{{ a.url }}">Détail et débat →</a>
    </article>
{% endmacro %}

{% block styles %}
    main { max-width: 78rem; }
    a.retour {
        font-family: var(--police);
        font-size: .9rem;
        text-decoration: none;
    }
    header.loi {
        background: #fff;
        border: 1px solid var(--bordure);
        border-top: 4px solid var(--bleu);
        border-radius: .25rem;
        padding: 1.5rem 2rem;
        margin: 1rem 0 2rem;
    }
    header.loi h1 {
        font-size: 1.4rem;
        margin: 0 0 .5rem;
        line-height: 1.4;
    }
    header.loi .meta {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
    }
    header.loi .meta a { margin-left: .5rem; }
    a.amendements {
        display: inline-block;
        font-family: var(--police);
        font-size: .9rem;
        color: #fff;
        background: var(--bleu);
        text-decoration: none;
        padding: .5rem 1rem;
        border-radius: .25rem;
        margin-top: .9rem;
    }
    a.amendements:hover { background: var(--bleu-hover); color: #fff; }
    .statut-ia {
        font-family: var(--police);
        font-size: .9rem;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: .7rem 1rem;
        margin: -1rem 0 2rem;
    }
    .statut-ia.complet { border-left: 4px solid #2e7d32; color: #2e7d32; background: #f1f8f1; }
    .statut-ia.en-cours { border-left: 4px solid var(--bleu); background: var(--fond); }
    .statut-ia.a-faire {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        border-left: 4px solid var(--gris);
        background: var(--fond);
    }
    .statut-ia.a-faire button {
        font-family: var(--police);
        font-size: .9rem;
        color: #fff;
        background: var(--bleu);
        border: none;
        border-radius: .25rem;
        padding: .5rem 1rem;
        cursor: pointer;
    }
    .statut-ia.a-faire button:hover { background: var(--bleu-hover); }
    p.sans-amendement {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        background: var(--fond);
        border-left: 3px solid var(--bordure);
        padding: .5rem .9rem;
        margin: .9rem 0 0;
    }
    /* Encadré « Au cœur du débat » : les amendements les plus discutés. */
    .encadre-debat {
        background: #fff;
        border: 1px solid var(--bordure);
        border-left: 4px solid #e8b500;
        border-radius: .25rem;
        padding: 1.1rem 1.5rem 1.3rem;
        margin: 0 0 2rem;
        font-family: var(--police);
    }
    .encadre-debat h2 {
        font-size: .95rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #a97e00;
        margin: 0 0 .3rem;
    }
    .encadre-debat .encadre-intro {
        font-size: .85rem;
        color: var(--gris);
        margin: 0 0 .9rem;
        max-width: 48rem;
    }
    .liste-debat {
        list-style: none;
        margin: 0;
        padding: 0;
        counter-reset: debat;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }
    .liste-debat li {
        counter-increment: debat;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: .5rem .8rem;
        padding: .5rem .7rem .5rem 2.2rem;
        position: relative;
        background: var(--fond);
        border-radius: .25rem;
    }
    .liste-debat li::before {
        content: counter(debat);
        position: absolute;
        left: .7rem;
        top: .5rem;
        font-variant-numeric: tabular-nums;
        font-weight: 700;
        color: #e8b500;
    }
    .liste-debat .lien-ancre {
        display: inline-flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: .5rem;
        text-decoration: none;
        color: var(--encre);
    }
    .liste-debat .lien-ancre:hover .debat-num { text-decoration: underline; }
    .liste-debat .badge {
        font-size: .72rem;
        padding: .1rem .55rem;
        border-radius: 2rem;
        white-space: nowrap;
        transform: translateY(-1px);
    }
    .liste-debat .badge.rejete { background: #fde3e3; color: var(--rouge); }
    .liste-debat .badge.adopte { background: #e3f5e1; color: #18753c; }
    .liste-debat .debat-num { font-weight: 600; white-space: nowrap; }
    .liste-debat .debat-auteur { font-size: .85rem; color: var(--gris); }
    .liste-debat .debat-detail {
        margin-left: auto;
        font-size: .82rem;
        white-space: nowrap;
        text-decoration: none;
    }
    /* Encadré « Les débats au Sénat » : même gabarit, liseré bordeaux Sénat. */
    .encadre-senat {
        background: #fff;
        border: 1px solid var(--bordure);
        border-left: 4px solid #8b1e3f;
        border-radius: .25rem;
        padding: 1.1rem 1.5rem 1.3rem;
        margin: 0 0 2rem;
        font-family: var(--police);
    }
    .encadre-senat h2 {
        font-size: .95rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #8b1e3f;
        margin: 0 0 .3rem;
    }
    .encadre-senat h3 {
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #8b1e3f;
        margin: 1.1rem 0 .5rem;
    }
    .encadre-senat .encadre-intro {
        font-size: .85rem;
        color: var(--gris);
        margin: 0 0 .9rem;
        max-width: 48rem;
    }
    .encadre-senat .liste-debat li::before { color: #8b1e3f; }
    .liste-seances-senat {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: .5rem .8rem;
    }
    .liste-seances-senat li {
        background: var(--fond);
        border-radius: .25rem;
        padding: .45rem .8rem;
        font-size: .88rem;
    }
    .liste-seances-senat a { font-weight: 600; text-decoration: none; }
    .liste-seances-senat a:hover { text-decoration: underline; }
    .liste-seances-senat .seance-mesure {
        display: block;
        font-size: .78rem;
        color: var(--gris);
    }
    .encadre-senat .senat-source {
        font-size: .8rem;
        color: var(--gris);
        margin: 1rem 0 0;
    }
    .encadre-senat .senat-indisponible {
        font-size: .85rem;
        color: var(--gris);
        margin: 0;
    }
    /* Cible d'une ancre cliquée depuis l'encadré : flash de mise en évidence. */
    .surligne-cible {
        animation: flash-cible 2s ease-out;
    }
    @keyframes flash-cible {
        0%, 25% { box-shadow: 0 0 0 3px #e8b500, 0 2px 10px rgba(0,0,0,.15); }
        100% { box-shadow: 0 0 0 0 transparent; }
    }

    details.visas {
        margin: 0 0 2rem;
        font-size: .95rem;
    }
    details.visas summary {
        font-family: var(--police);
        font-size: .9rem;
        color: var(--bleu);
        cursor: pointer;
    }
    details.visas .contenu {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1rem 1.5rem;
        margin-top: .5rem;
        color: var(--gris);
    }

    /* Mise en page deux colonnes : la loi à gauche, les amendements en regard. */
    .loi-layout {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 22rem;
        gap: 2.5rem;
        align-items: start;
    }

    article.article {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1.25rem 2rem;
        margin-bottom: 1rem;
    }
    article.article h2 {
        font-family: var(--police);
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--bleu);
        border-bottom: 1px solid var(--bordure);
        padding-bottom: .5rem;
        margin: 0 0 .75rem;
    }
    article.article blockquote {
        border-left: 3px solid var(--bordure);
        margin-left: 0;
        padding-left: 1rem;
    }
    section.signataires {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1.25rem 2rem;
        margin: 2rem 0;
        font-style: italic;
        color: var(--gris);
    }
    .filtres-amendements {
        position: sticky;
        top: .5rem;
        z-index: 5;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .75rem 1.5rem;
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        box-shadow: 0 2px 6px rgba(0,0,0,.08);
        padding: .6rem 1rem;
        margin: 0 0 1.5rem;
        font-family: var(--police);
        font-size: .85rem;
    }
    .filtres-amendements .filtre-recherche {
        flex: 1 1 15rem;
        min-width: 11rem;
        padding: .4rem .75rem;
        border: 1px solid var(--bordure);
        border-radius: 2rem;
        font: inherit;
        color: var(--encre);
    }
    .filtres-amendements .filtre-recherche:focus {
        outline: none;
        border-color: var(--bleu);
        box-shadow: 0 0 0 2px rgba(0,0,145,.15);
    }
    .filtres-amendements .filtre-sort {
        display: flex;
        border: 1px solid var(--bordure);
        border-radius: 2rem;
        overflow: hidden;
    }
    .filtres-amendements .filtre-sort button {
        border: none;
        background: #fff;
        padding: .35rem .9rem;
        cursor: pointer;
        font: inherit;
        color: var(--gris);
    }
    .filtres-amendements .filtre-sort button.actif {
        background: var(--bleu);
        color: #fff;
    }
    .filtres-amendements .filtre-impact {
        display: flex;
        align-items: center;
        gap: .5rem;
        color: var(--gris);
    }
    .filtres-amendements .filtre-impact input {
        accent-color: var(--bleu);
        width: 9rem;
    }
    .filtres-amendements .filtre-impact output {
        min-width: 3rem;
        font-variant-numeric: tabular-nums;
    }
    .filtres-amendements select {
        padding: .35rem .6rem;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        background: #fff;
        font: inherit;
        color: var(--encre);
    }
    /* Légende de l'échelle d'impact (0–100) attribuée par l'IA à chaque amendement. */
    .legende-impact {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .35rem .7rem;
        font-family: var(--police);
        font-size: .8rem;
        color: var(--gris);
        margin: -0.9rem 0 1.6rem;
    }
    .legende-impact .legende-titre { font-weight: 600; color: var(--encre); }
    .echelle-impact {
        display: flex;
        flex-wrap: wrap;
        list-style: none;
        margin: 0;
        padding: 0;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        overflow: hidden;
    }
    .echelle-impact li {
        padding: .2rem .6rem;
        white-space: nowrap;
    }
    .echelle-impact li b {
        font-variant-numeric: tabular-nums;
        margin-right: .3rem;
    }
    .echelle-impact li:nth-child(1) { background: #f3f0ff; color: #4a3fa8; }
    .echelle-impact li:nth-child(2) { background: #ddd4fb; color: #4a3fa8; }
    .echelle-impact li:nth-child(3) { background: #b9a9f2; color: #241a63; }
    .echelle-impact li:nth-child(4) { background: #7c6ce0; color: #fff; }
    .carte-intention {
        font-size: .82rem;
        color: #4a3fa8;
        background: #f3f0ff;
        border-radius: .25rem;
        padding: .35rem .6rem;
        margin: .4rem 0;
    }
    .carte-intention strong {
        font-family: var(--police);
        font-size: .7rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }
    .filtres-amendements .filtre-compteur {
        margin-left: auto;
        color: var(--gris);
    }
    .filtres-amendements .filtre-compteur b {
        color: var(--encre);
        font-variant-numeric: tabular-nums;
    }
    .alinea-amende.estompe {
        background: transparent;
        border-left-color: transparent;
        cursor: default;
        pointer-events: none;
    }
    .alinea-amende.estompe::after { display: none; }
    .note[hidden], .carte-amendement[hidden], .bloc-division[hidden],
    .fiche-amendement[hidden] { display: none !important; }
    /* Navigation flottante entre les passages amendés (Rayon X). */
    .nav-amendements {
        position: fixed;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .35rem;
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.18);
        padding: .4rem .3rem;
    }
    .nav-amendements[hidden] { display: none; }
    .nav-amendements button {
        width: 2rem;
        height: 2rem;
        border: none;
        border-radius: 50%;
        background: var(--bleu);
        color: #fff;
        font-size: .85rem;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .nav-amendements button:hover { background: var(--bleu-hover); }
    .nav-amendements .nav-compteur {
        font-family: var(--police);
        font-size: .68rem;
        color: var(--gris);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }
    @media (max-width: 60rem) {
        .nav-amendements { right: .5rem; }
    }
    p.legende-rayon-x {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        background: #fef7e0;
        border-left: 3px solid #e8b500;
        padding: .6rem 1rem;
    }
    .alinea-amende {
        background: #fce8a6;
        cursor: pointer;
        padding: .05em .12em;
        border-radius: .18em;
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
        transition: background .15s, box-shadow .15s;
    }
    .alinea-amende:hover { background: #f9dc7a; }
    .alinea-amende.actif {
        background: #f6d34e;
        box-shadow: 0 0 0 2px #e8b500;
    }
    .alinea-amende::after {
        content: attr(data-nb);
        font-family: var(--police);
        font-size: .7rem;
        font-weight: 600;
        color: #fff;
        background: #e8b500;
        border-radius: 2rem;
        padding: 0 .45rem;
        margin-left: .45rem;
        vertical-align: super;
    }

    /* Colonne de droite : notes de marge alignées sur leur passage. */
    .colonne-notes { position: relative; }
    .colonne-notes .titre-colonne {
        display: none;
        font-family: var(--police);
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--gris);
        margin: 0 0 1rem;
    }
    .note {
        position: absolute;
        left: 0;
        right: 0;
        border-left: 3px solid #e8b500;
        background: #fff;
        border-radius: .25rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
        transition: box-shadow .15s, transform .15s;
    }
    .note.actif {
        box-shadow: 0 0 0 2px #e8b500, 0 2px 8px rgba(0,0,0,.12);
    }
    .note .note-tete {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        border: none;
        background: none;
        text-align: left;
        cursor: pointer;
        font-family: var(--police);
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--gris);
        padding: .5rem .9rem;
    }
    .note .note-tete::after { content: '↩'; color: #e8b500; }
    .fiche-amendement {
        padding: .3rem .9rem 1rem;
    }
    .fiche-amendement + .fiche-amendement {
        border-top: 1px solid var(--bordure);
        padding-top: .8rem;
    }
    /* Seule l'intention est affichée : son opacité traduit le poids de
       l'amendement (impact + ambiguïté) — les changements techniques
       s'effacent, les amendements lourds ou ambigus ressortent. Le survol
       rend la fiche pleinement lisible. */
    .fiche-amendement .intention-fiche {
        font-size: .85rem;
        line-height: 1.45;
        margin: 0 0 .5rem;
        transition: opacity .15s;
    }
    .fiche-amendement:hover .intention-fiche { opacity: 1 !important; }
    .fiche-amendement .intention-fiche.vide {
        color: #b0b0b0;
        font-style: italic;
    }
    .fiche-amendement .lien-detail {
        font-family: var(--police);
        font-size: .82rem;
        text-decoration: none;
    }

    /* Section « hors texte » : amendements rejetés et adoptés non localisés,
       qui n'ont pas de passage surligné dans la loi. */
    .hors-texte {
        margin: 3rem 0 1rem;
        border-top: 2px solid var(--bordure);
        padding-top: 1.5rem;
    }
    .hors-texte .titre-hors-texte {
        font-family: var(--police);
        font-size: 1.15rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        margin: 0 0 .3rem;
    }
    .compte {
        font-family: var(--police);
        font-size: .8rem;
        font-weight: 600;
        color: var(--gris);
        background: var(--fond);
        border: 1px solid var(--bordure);
        border-radius: 2rem;
        padding: .05rem .6rem;
    }
    .hors-texte .intro-hors-texte {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        margin: 0 0 1.2rem;
        max-width: 46rem;
    }
    .bloc-division { margin-top: 2rem; }
    /* Amendements rattachés à un article : repliés sous son texte. */
    details.amendements-article {
        margin-top: 1rem;
        border-top: 1px dashed var(--bordure);
        padding-top: .75rem;
    }
    details.amendements-article summary {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--bleu);
        cursor: pointer;
    }
    .bloc-division .titre-division {
        font-family: var(--police);
        font-size: 1rem;
        font-weight: 600;
        color: var(--bleu);
        display: flex;
        align-items: center;
        gap: .6rem;
        margin: 0 0 .2rem;
        padding-bottom: .4rem;
        border-bottom: 1px solid var(--bordure);
    }
    .grille-cartes {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }
    .carte-amendement {
        background: #fff;
        border: 1px solid var(--bordure);
        border-left: 3px solid var(--gris);
        border-radius: .25rem;
        padding: .8rem 1rem;
        display: flex;
        flex-direction: column;
        font-family: var(--police);
    }
    .carte-amendement.classe-rejete { border-left-color: var(--rouge); }
    .carte-amendement.classe-adopte { border-left-color: #18753c; }
    .carte-tete {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .5rem;
        margin-bottom: .45rem;
    }
    .carte-amendement .badge {
        font-size: .72rem;
        padding: .1rem .55rem;
        border-radius: 2rem;
        white-space: nowrap;
    }
    .carte-amendement .badge.rejete { background: #fde3e3; color: var(--rouge); }
    .carte-amendement .badge.adopte { background: #e3f5e1; color: #18753c; }
    .carte-num { font-size: .8rem; color: var(--gris); white-space: nowrap; }
    .carte-meta {
        font-size: .78rem;
        color: var(--gris);
        margin: 0 0 .5rem;
        line-height: 1.4;
    }
    .carte-resume {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: .92rem;
        line-height: 1.45;
        color: var(--encre);
        margin: 0 0 .6rem;
    }
    .carte-resume.vide { color: #b0b0b0; font-style: italic; }
    .carte-badges {
        display: flex;
        flex-wrap: wrap;
        gap: .3rem;
        margin-bottom: .6rem;
    }
    .carte-badges .badge-ia {
        font-size: .7rem;
        background: #e9e5ff;
        color: #4a3fa8;
        padding: .08rem .5rem;
        border-radius: 2rem;
    }
    .carte-lien {
        font-size: .82rem;
        text-decoration: none;
        margin-top: auto;
    }

    /* Sous les 60rem : une seule colonne, les notes défilent sous le texte. */
    @media (max-width: 60rem) {
        .loi-layout { display: block; }
        .colonne-notes { margin-top: 2.5rem; }
        .colonne-notes .titre-colonne { display: block; }
        .note {
            position: static !important;
            width: auto;
            margin-bottom: 1rem;
        }
    }
{% endblock %}

{% block body %}
    <a class="retour" href="{{ path('loi_index') }}">← Retour à la liste des lois</a>

    <header class="loi">
        <h1>{{ loi.titre ?? loi.id }}</h1>
        <div class="meta">
            {% if loi.origine_publi %}{{ loi.origine_publi }}{% endif %}
            {% if loi.eli %}<a href="{{ loi.eli }}" target="_blank" rel="noopener">Voir sur Légifrance ↗</a>{% endif %}
        </div>
        {% if nbAmendements %}
            <a class="amendements" href="{{ path('loi_amendements', {id: loi.id}) }}">
                Voir les {{ nbAmendements|format_number(locale='fr') }} amendements →
            </a>
        {% elseif nbAmendements is same as(0) %}
            <p class="sans-amendement">Aucun amendement examiné à l'Assemblée nationale pour ce texte
                (adopté conforme — les amendements éventuels ont été déposés au Sénat).</p>
        {% endif %}
    </header>

    {% if statutIa == 'complet' %}
        <p class="statut-ia complet">✓ Tous les amendements ont été traités
            ({{ totalJuges }} analyse{{ totalJuges > 1 ? 's' : '' }} IA).</p>
    {% elseif statutIa == 'en_cours' %}
        <p class="statut-ia en-cours">Les amendements de cette loi sont en cours de traitement —
            {{ analysesFaites }}/{{ totalJuges }} analysés. Rechargez la page pour suivre l'avancement.</p>
    {% elseif statutIa == 'a_faire' %}
        <form class="statut-ia a-faire" method="post" action="{{ path('loi_analyser', {id: loi.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('analyser' ~ loi.id) }}">
            <span>Cette loi n'a pas encore été traitée{% if analysesFaites > 0 %}
                entièrement ({{ analysesFaites }}/{{ totalJuges }} amendements analysés){% endif %},
                cliquez ici pour le faire, cela peut prendre quelques heures.</span>
            <button type="submit">Lancer l'analyse IA</button>
        </form>
    {% endif %}

    {% if topDebat is not empty %}
        <aside class="encadre-debat">
            <h2>Au cœur du débat</h2>
            <p class="encadre-intro">Les amendements qui ont suscité les échanges les plus nourris en
                séance publique, mesurés à l'ampleur de leur discussion dans le compte rendu intégral.</p>
            <ol class="liste-debat">
                {% for d in topDebat %}
                    <li>
                        <a class="lien-ancre classe-{{ d.classe }}" href="#{{ d.ancre }}" data-ancre="{{ d.ancre }}">
                            <span class="badge {{ d.classe }}">{{ d.statut }}</span>
                            <span class="debat-num">n° {{ d.numero }}</span>
                            {% if d.auteur and d.auteur != '—' %}<span class="debat-auteur">{{ d.auteur }}{% if d.groupe %} ({{ d.groupe }}){% endif %}</span>{% endif %}
                        </a>
                        <a class="debat-detail" href="{{ d.url }}">Détail et débat →</a>
                    </li>
                {% endfor %}
            </ol>
        </aside>
    {% endif %}

    {% if senat %}
        <aside class="encadre-senat">
            <h2>Les débats au Sénat</h2>
            {% if senat.seances is not empty %}
                <p class="encadre-intro">Le texte a aussi été discuté en séance publique au Sénat —
                    comptes rendus intégraux importés depuis senat.fr, rattachés à la loi via le
                    dossier sénatorial.</p>
                <ul class="liste-seances-senat">
                    {% for s in senat.seances %}
                        <li>
                            <a href="{{ s.url_page }}" target="_blank" rel="noopener">Séance du {{ s.date_seance|date('d/m/Y') }} ↗</a>
                            <span class="seance-mesure">{{ s.nb_paroles|format_number(locale='fr') }} paroles
                                · {{ s.nb_orateurs }} orateur{{ s.nb_orateurs > 1 ? 's' }}</span>
                        </li>
                    {% endfor %}
                </ul>
                {% if senat.top is not empty %}
                    <h3>Au cœur du débat sénatorial</h3>
                    <ol class="liste-debat">
                        {% for d in senat.top %}
                            <li>
                                <a class="lien-ancre" href="{{ d.url }}" target="_blank" rel="noopener">
                                    <span class="badge {{ 'Adopté' in d.sort ? 'adopte' : 'rejete' }}">{{ d.sort }}</span>
                                    <span class="debat-num">n° {{ d.numero }}</span>
                                    {% if d.auteur %}<span class="debat-auteur">{{ d.auteur }}</span>{% endif %}
                                </a>
                                <span class="debat-detail">{{ d.nb_cit }} citations dans le CRI · senat.fr ↗</span>
                            </li>
                        {% endfor %}
                    </ol>
                {% endif %}
            {% else %}
                <p class="senat-indisponible">Le dossier sénatorial existe mais ses comptes rendus de
                    séance n'ont pas encore été importés
                    (<code>app:import:comptes-rendus-senat --loi {{ loi.num }}</code>).</p>
            {% endif %}
            <p class="senat-source">{{ senat.nbAmendements|format_number(locale='fr') }} amendements déposés
                au Sénat (séance et commission) ·
                <a href="{{ senat.dossier.url }}" target="_blank" rel="noopener">Dossier législatif sur senat.fr ↗</a></p>
        </aside>
    {% endif %}

    {% if loi.visas %}
        <details class="visas">
            <summary>Visas et préambule</summary>
            <div class="contenu">{{ loi.visas|raw }}</div>
        </details>
    {% endif %}

    {% if provenance is not empty %}
        <p class="legende-rayon-x">Rayon X : les passages surlignés proviennent d'amendements adoptés
            à l'Assemblée nationale. En regard, dans la colonne de droite, l'amendement à l'origine de
            chaque passage — cliquez sur un passage ou sa note pour les relier.</p>
    {% endif %}

    {% if provenance is not empty or autresParDivision is not empty %}
        {% set libellesCategorie = {
            coordination: 'Coordination', redactionnel: 'Rédactionnel',
            simplification: 'Simplification', correction: 'Correction',
            precision: 'Précision', consequence: 'Conséquence',
            coherence: 'Cohérence', fond: 'Fond',
        } %}
        <div class="filtres-amendements">
            <input type="search" id="filtre-recherche" class="filtre-recherche"
                   placeholder="Rechercher un mot-clé (résumé, intention, auteur…)"
                   aria-label="Rechercher un mot-clé dans les amendements">
            <div class="filtre-sort" role="group" aria-label="Filtrer par sort">
                <button type="button" class="actif" data-sort="">Tous</button>
                <button type="button" data-sort="adopte">Adoptés</button>
                <button type="button" data-sort="rejete">Rejetés</button>
            </div>
            <label class="filtre-impact" title="Masque les amendements sous ce score d'impact (ceux encore en attente d'analyse sont masqués dès que le seuil dépasse zéro)">
                Impact
                <input type="range" id="filtre-impact" min="0" max="100" step="5" value="0">
                <output id="filtre-impact-valeur">tous</output>
            </label>
            <select id="filtre-categorie" aria-label="Filtrer par catégorie">
                <option value="">Toutes les catégories</option>
                {% for cle, libelle in libellesCategorie %}
                    <option value="{{ cle }}">{{ libelle }}</option>
                {% endfor %}
            </select>
            <span class="filtre-compteur"><b id="filtre-compte">—</b> amendement<span id="filtre-compte-pluriel">s</span> affiché<span id="filtre-compte-pluriel2">s</span></span>
        </div>

        <div class="legende-impact">
            <span class="legende-titre">Score d'impact</span> — estimé par l'IA, l'ampleur du changement apporté (ou proposé) au texte :
            <ol class="echelle-impact">
                <li><b>0–20</b>technique</li>
                <li><b>21–50</b>ajustement limité</li>
                <li><b>51–79</b>changement notable</li>
                <li><b>80–100</b>changement majeur</li>
            </ol>
        </div>
    {% endif %}

    {% import _self as ui %}

    <div class="loi-layout">
        <div class="colonne-texte">
            {% if articles is empty %}
                <p>Le contenu de cette loi n'est pas disponible dans la base.</p>
            {% else %}
                {% for article in articles %}
                    <article class="article" id="article-{{ article.num }}">
                        <h2>Article {{ article.num }}</h2>
                        <div>{{ article.contenu|raw }}</div>
                        {% set cartes = amendementsParArticle[article.num] ?? [] %}
                        {% if cartes is not empty %}
                            <details class="bloc-division amendements-article">
                                <summary>Amendements examinés sur cet article <span class="compte">{{ cartes|length }}</span></summary>
                                <div class="grille-cartes">
                                    {% for a in cartes %}{{ ui.carteAmendement(a) }}{% endfor %}
                                </div>
                            </details>
                        {% endif %}
                    </article>
                {% endfor %}
            {% endif %}

            {% if loi.signataires %}
                <section class="signataires">{{ loi.signataires|raw }}</section>
            {% endif %}
        </div>

        {% if provenance is not empty %}
            <aside class="colonne-notes" id="colonne-notes">
                <p class="titre-colonne">Amendements à l'origine du texte</p>
            </aside>
        {% endif %}
    </div>

    {% if provenance is not empty %}
        <nav class="nav-amendements" id="nav-amendements" aria-label="Naviguer entre les passages amendés" hidden>
            <button type="button" id="nav-prec" aria-label="Passage amendé précédent" title="Passage amendé précédent">▲</button>
            <span class="nav-compteur" id="nav-compteur" aria-live="polite"></span>
            <button type="button" id="nav-suiv" aria-label="Passage amendé suivant" title="Passage amendé suivant">▼</button>
        </nav>
    {% endif %}

    {% if autresParDivision is not empty %}
        <section class="hors-texte">
            <h2 class="titre-hors-texte">Amendements hors du texte promulgué <span class="compte">{{ autresTotal }}</span></h2>
            <p class="intro-hors-texte">Les amendements visant des divisions qu'on ne retrouve pas dans la
                loi promulguée : insertions « après l'article… », articles renumérotés ou supprimés au cours
                de la navette, annexes et états. La numérotation est celle de l'examen à l'Assemblée. Le badge
                indique le sort — adopté ou rejeté ; le résumé, ce que l'amendement changeait ou proposait.</p>

            {% for division, cartes in autresParDivision %}
                <div class="bloc-division">
                    <h3 class="titre-division">{{ division }} <span class="compte">{{ cartes|length }}</span></h3>
                    <div class="grille-cartes">
                        {% for a in cartes %}{{ ui.carteAmendement(a) }}{% endfor %}
                    </div>
                </div>
            {% endfor %}
        </section>
    {% endif %}

    {% if provenance is not empty %}
        <script type="application/json" id="donnees-provenance">{{ provenance|json_encode(constant('JSON_HEX_TAG'))|raw }}</script>
        <script>
            const amendements = JSON.parse(document.getElementById('donnees-provenance').textContent);
            const colonne = document.getElementById('colonne-notes');
            const layout = document.querySelector('.loi-layout');
            const passages = [...document.querySelectorAll('.alinea-amende')];

            // Fiche minimale : l'intention seule, dont l'opacité traduit le
            // poids de l'amendement (impact + ambiguïté, plafonné à 100), et
            // le lien vers la page de détail.
            function construireFiche(a) {
                const fiche = document.createElement('article');
                fiche.className = 'fiche-amendement';
                fiche.dataset.uid = a.uid;
                fiche.dataset.sort = a.classe ?? 'adopte';
                fiche.dataset.impact = a.scoreImpactIa ?? -1;
                fiche.dataset.categorie = a.categorieIa ?? '';
                fiche.dataset.recherche = [a.numero, a.intentionIa].filter(Boolean).join(' ').toLowerCase();

                const intention = document.createElement('p');
                intention.className = 'intention-fiche';
                if (a.intentionIa) {
                    intention.textContent = a.intentionIa;
                    intention.style.opacity = Math.min(1, ((a.scoreImpactIa ?? 0) + (a.ambiguiteIa ?? 0)) / 100);
                } else {
                    intention.textContent = 'Analyse en cours…';
                    intention.classList.add('vide');
                }
                fiche.appendChild(intention);

                const lien = document.createElement('a');
                lien.className = 'lien-detail';
                lien.href = a.url;
                lien.title = `Amendement n° ${a.numero}`;
                lien.textContent = 'Détail →';
                fiche.appendChild(lien);

                return fiche;
            }

            // Une note par passage surligné : elle contient le ou les amendements
            // cités par data-amendements, dans l'ordre chronologique de dépôt.
            // Ancre #amdt-<uid> posée une seule fois par amendement (un même
            // amendement peut annoter plusieurs passages) : cible des liens de
            // l'encadré « Au cœur du débat » pour les amendements sans carte.
            const ancresPosees = new Set();
            const paires = [];
            passages.forEach((passage, i) => {
                passage.id = passage.id || 'al-' + i;

                const uids = (passage.dataset.amendements || '').split(',');
                const fiches = uids.filter((uid) => amendements[uid])
                    .map((uid) => ({ uid, ...amendements[uid] }))
                    .sort((a, b) => (a.date || '').localeCompare(b.date || ''));
                if (fiches.length === 0) return;

                const note = document.createElement('div');
                note.className = 'note';
                note.id = 'note-' + i;

                const tete = document.createElement('button');
                tete.type = 'button';
                tete.className = 'note-tete';
                const label = document.createElement('span');
                label.textContent = fiches.length > 1
                    ? fiches.length + ' amendements' : '1 amendement';
                tete.appendChild(label);
                note.appendChild(tete);

                fiches.forEach((a) => {
                    const fiche = construireFiche(a);
                    if (!ancresPosees.has(a.uid)) {
                        fiche.id = 'amdt-' + a.uid;
                        ancresPosees.add(a.uid);
                    }
                    note.appendChild(fiche);
                });
                colonne.appendChild(note);

                paires.push({ passage, note });

                passage.title = 'Voir l\'amendement à l\'origine de ce passage';
                passage.addEventListener('click', () => {
                    activer(passage, note);
                    note.scrollIntoView({ behavior: 'smooth', block: 'center' });
                });
                note.addEventListener('click', (e) => {
                    if (e.target.closest('a')) return;
                    activer(passage, note);
                    passage.scrollIntoView({ behavior: 'smooth', block: 'center' });
                });
            });

            function activer(passage, note) {
                for (const p of paires) {
                    p.passage.classList.toggle('actif', p.passage === passage);
                    p.note.classList.toggle('actif', p.note === note);
                }
            }

            // Aligne chaque note sur son passage ; en cas de collision, la note
            // suivante est repoussée vers le bas. Ignoré en mono-colonne (mobile).
            const monoColonne = window.matchMedia('(max-width: 60rem)');
            function positionnerNotes() {
                if (monoColonne.matches) {
                    for (const { note } of paires) note.style.top = '';
                    colonne.style.minHeight = '';
                    return;
                }
                const origine = layout.getBoundingClientRect().top + window.scrollY;
                let curseur = 0;
                for (const { passage, note } of paires) {
                    if (note.hidden) continue;
                    const cible = passage.getBoundingClientRect().top + window.scrollY - origine;
                    const top = Math.max(cible, curseur);
                    note.style.top = top + 'px';
                    curseur = top + note.offsetHeight + 16;
                }
                colonne.style.minHeight = curseur + 'px';
            }

            // Flèches flottantes : saut au passage amendé suivant / précédent,
            // en ignorant ceux masqués par les filtres (classe « estompe ».)
            const navBarre = document.getElementById('nav-amendements');
            const navCompteur = document.getElementById('nav-compteur');

            function passagesVisibles() {
                return passages.filter((p) => !p.classList.contains('estompe'));
            }

            function majNav() {
                const total = passagesVisibles().length;
                navBarre.hidden = total === 0;
                navCompteur.textContent = total;
            }

            function naviguer(direction) {
                const visibles = passagesVisibles();
                if (visibles.length === 0) return;

                // On avance à partir du passage actif ; à défaut (premier appel),
                // on part de la position de lecture (ligne à 30 % de la hauteur).
                const actif = document.querySelector('.alinea-amende.actif:not(.estompe)');
                let idx = actif ? visibles.indexOf(actif) : -1;

                if (idx === -1) {
                    const ligne = window.innerHeight * 0.3;
                    if (direction > 0) {
                        idx = visibles.findIndex((p) => p.getBoundingClientRect().top > ligne + 4);
                        if (idx === -1) idx = 0;
                    } else {
                        const avant = visibles.filter((p) => p.getBoundingClientRect().top < ligne - 4);
                        idx = avant.length ? visibles.indexOf(avant[avant.length - 1]) : visibles.length - 1;
                    }
                } else {
                    idx = (idx + direction + visibles.length) % visibles.length;
                }

                const cible = visibles[idx];
                const paire = paires.find((x) => x.passage === cible);
                if (paire) activer(paire.passage, paire.note);
                cible.scrollIntoView({ behavior: 'smooth', block: 'center' });
                navCompteur.textContent = (idx + 1) + ' / ' + visibles.length;
            }

            document.getElementById('nav-suiv').addEventListener('click', () => naviguer(1));
            document.getElementById('nav-prec').addEventListener('click', () => naviguer(-1));
            majNav();

            // Exposé pour la barre de filtres (sort, impact, catégorie).
            window.alinea = { paires, positionnerNotes, majNav };

            positionnerNotes();
            window.addEventListener('load', positionnerNotes);
            monoColonne.addEventListener('change', positionnerNotes);
            let minuteur;
            window.addEventListener('resize', () => {
                clearTimeout(minuteur);
                minuteur = setTimeout(positionnerNotes, 150);
            });
        </script>
    {% endif %}

    {% if provenance is not empty or autresParDivision is not empty %}
        <script>
            (() => {
                const filtres = { sort: '', impactMin: 0, categorie: '', motcle: '' };

                // Recherche insensible à la casse et aux accents.
                const norm = (s) => (s || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

                // On normalise une fois pour toutes le texte cherchable des cartes
                // et des fiches (rendues juste avant ce script).
                document.querySelectorAll('[data-recherche]').forEach((el) => {
                    el.dataset.recherche = norm(el.dataset.recherche);
                });

                // d = dataset portant data-sort / data-impact / data-categorie /
                // data-recherche. Les amendements pas encore analysés (impact -1)
                // disparaissent dès que le seuil d'impact dépasse zéro.
                const correspond = (d) => (filtres.sort === '' || d.sort === filtres.sort)
                    && (filtres.impactMin === 0 || parseInt(d.impact ?? '-1', 10) >= filtres.impactMin)
                    && (filtres.categorie === '' || d.categorie === filtres.categorie)
                    && (filtres.motcle === '' || (d.recherche ?? '').includes(filtres.motcle));

                function appliquer() {
                    let totalAffiche = 0;

                    // Cartes « amendements par article ».
                    document.querySelectorAll('.bloc-division').forEach((bloc) => {
                        let visibles = 0;
                        bloc.querySelectorAll('.carte-amendement').forEach((carte) => {
                            const ok = correspond(carte.dataset);
                            carte.hidden = !ok;
                            if (ok) visibles++;
                        });
                        bloc.hidden = visibles === 0;
                        const compte = bloc.querySelector('.compte');
                        if (compte) compte.textContent = visibles;
                        totalAffiche += visibles;

                        // Une recherche active déplie les articles qui ont des
                        // résultats, pour rendre les correspondances visibles.
                        if (bloc.tagName === 'DETAILS' && filtres.motcle !== '') {
                            bloc.open = visibles > 0;
                        }
                    });

                    // Notes de marge du Rayon X : une note disparaît quand tous
                    // ses amendements sont filtrés, et son passage s'estompe.
                    // Un même amendement peut annoter plusieurs passages : on le
                    // compte une seule fois (uid).
                    if (window.alinea) {
                        const uidsVisibles = new Set();
                        for (const { passage, note } of window.alinea.paires) {
                            let visibles = 0;
                            note.querySelectorAll('.fiche-amendement').forEach((fiche) => {
                                const ok = correspond(fiche.dataset);
                                fiche.hidden = !ok;
                                if (ok) {
                                    visibles++;
                                    uidsVisibles.add(fiche.dataset.uid);
                                }
                            });
                            note.hidden = visibles === 0;
                            passage.classList.toggle('estompe', visibles === 0);
                        }
                        window.alinea.positionnerNotes();
                        window.alinea.majNav?.();
                        totalAffiche += uidsVisibles.size;
                    }

                    document.getElementById('filtre-compte').textContent =
                        totalAffiche.toLocaleString('fr-FR');
                    const pluriel = totalAffiche > 1 ? 's' : '';
                    document.getElementById('filtre-compte-pluriel').textContent = pluriel;
                    document.getElementById('filtre-compte-pluriel2').textContent = pluriel;
                }

                const boutons = document.querySelectorAll('.filtres-amendements .filtre-sort button');
                boutons.forEach((bouton) => {
                    bouton.addEventListener('click', () => {
                        boutons.forEach((b) => b.classList.toggle('actif', b === bouton));
                        filtres.sort = bouton.dataset.sort;
                        appliquer();
                    });
                });

                const curseur = document.getElementById('filtre-impact');
                const valeur = document.getElementById('filtre-impact-valeur');
                curseur.addEventListener('input', () => {
                    filtres.impactMin = parseInt(curseur.value, 10);
                    valeur.textContent = filtres.impactMin > 0 ? '≥ ' + filtres.impactMin : 'tous';
                    appliquer();
                });

                document.getElementById('filtre-categorie').addEventListener('change', (e) => {
                    filtres.categorie = e.target.value;
                    appliquer();
                });

                // Recherche par mot-clé (débounce léger pour ne pas filtrer à
                // chaque frappe sur les longues listes).
                const recherche = document.getElementById('filtre-recherche');
                let minuteurRecherche;
                recherche.addEventListener('input', () => {
                    clearTimeout(minuteurRecherche);
                    minuteurRecherche = setTimeout(() => {
                        filtres.motcle = norm(recherche.value.trim());
                        appliquer();
                    }, 150);
                });

                // Compteur initial (aucun filtre actif).
                appliquer();
            })();
        </script>
    {% endif %}

    {% if topDebat is not empty %}
        <script>
            // Liens de l'encadré « Au cœur du débat » : défilement vers
            // l'amendement dans la page (carte ou note de marge). S'il est replié
            // sous un article (<details>), on l'ouvre d'abord.
            document.querySelectorAll('.encadre-debat .lien-ancre').forEach((lien) => {
                lien.addEventListener('click', (e) => {
                    const cible = document.getElementById(lien.dataset.ancre);
                    if (!cible) return; // ancre absente : on laisse le comportement par défaut
                    e.preventDefault();
                    const repli = cible.closest('details');
                    if (repli) repli.open = true;
                    cible.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    cible.classList.remove('surligne-cible');
                    void cible.offsetWidth; // relance l'animation si déjà jouée
                    cible.classList.add('surligne-cible');
                });
            });
        </script>
    {% endif %}
{% endblock %}
