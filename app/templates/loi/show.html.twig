{% extends 'base.html.twig' %}

{% block title %}{{ loi.num ? 'Loi n° ' ~ loi.num : loi.titre }} — Alinéa{% endblock %}

{% block styles %}
    a.retour {
        font-family: system-ui, sans-serif;
        font-size: .9rem;
        text-decoration: none;
    }
    header.loi {
        background: #fff;
        border: 1px solid var(--bordure);
        border-top: 4px solid var(--bleu);
        border-radius: .25rem;
        padding: 1.5rem 2rem;
        margin: 1rem 0 2rem;
    }
    header.loi h1 {
        font-size: 1.4rem;
        margin: 0 0 .5rem;
        line-height: 1.4;
    }
    header.loi .meta {
        font-family: system-ui, sans-serif;
        font-size: .85rem;
        color: var(--gris);
    }
    header.loi .meta a { margin-left: .5rem; }
    a.amendements {
        display: inline-block;
        font-family: system-ui, sans-serif;
        font-size: .9rem;
        color: #fff;
        background: var(--bleu);
        text-decoration: none;
        padding: .5rem 1rem;
        border-radius: .25rem;
        margin-top: .9rem;
    }
    a.amendements:hover { background: var(--bleu-hover); color: #fff; }
    p.sans-amendement {
        font-family: system-ui, sans-serif;
        font-size: .85rem;
        color: var(--gris);
        background: var(--fond);
        border-left: 3px solid var(--bordure);
        padding: .5rem .9rem;
        margin: .9rem 0 0;
    }
    details.visas {
        margin: 0 0 2rem;
        font-size: .95rem;
    }
    details.visas summary {
        font-family: system-ui, sans-serif;
        font-size: .9rem;
        color: var(--bleu);
        cursor: pointer;
    }
    details.visas .contenu {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1rem 1.5rem;
        margin-top: .5rem;
        color: var(--gris);
    }
    article.article {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1.25rem 2rem;
        margin-bottom: 1rem;
    }
    article.article h2 {
        font-family: system-ui, sans-serif;
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--bleu);
        border-bottom: 1px solid var(--bordure);
        padding-bottom: .5rem;
        margin: 0 0 .75rem;
    }
    article.article blockquote {
        border-left: 3px solid var(--bordure);
        margin-left: 0;
        padding-left: 1rem;
    }
    section.signataires {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1.25rem 2rem;
        margin: 2rem 0;
        font-style: italic;
        color: var(--gris);
    }
    p.legende-rayon-x {
        font-family: system-ui, sans-serif;
        font-size: .85rem;
        color: var(--gris);
        background: #fef7e0;
        border-left: 3px solid #e8b500;
        padding: .6rem 1rem;
    }
    .alinea-amende {
        background: #fef7e0;
        cursor: pointer;
        border-left: 3px solid #e8b500;
        padding-left: .75rem;
        transition: background .15s;
    }
    .alinea-amende:hover { background: #fdedb5; }
    .alinea-amende::after {
        content: attr(data-nb);
        font-family: system-ui, sans-serif;
        font-size: .7rem;
        font-weight: 600;
        color: #fff;
        background: #e8b500;
        border-radius: 2rem;
        padding: 0 .45rem;
        margin-left: .45rem;
        vertical-align: super;
    }
    dialog#modale-amendements {
        border: none;
        border-top: 4px solid var(--bleu);
        border-radius: .25rem;
        box-shadow: 0 .5rem 2rem rgba(0,0,0,.25);
        padding: 0;
        width: min(46rem, 92vw);
        max-height: 85vh;
    }
    dialog#modale-amendements::backdrop { background: rgba(0,0,0,.45); }
    dialog#modale-amendements .entete {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--bordure);
        font-family: system-ui, sans-serif;
    }
    dialog#modale-amendements .entete h2 { font-size: 1rem; margin: 0; }
    dialog#modale-amendements .entete button {
        border: none;
        background: none;
        font-size: 1.3rem;
        cursor: pointer;
        color: var(--gris);
    }
    dialog#modale-amendements .corps {
        padding: 1rem 1.5rem;
        overflow-y: auto;
        max-height: calc(85vh - 4rem);
    }
    .fiche-amendement {
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1rem;
    }
    .fiche-amendement .titre-fiche {
        font-family: system-ui, sans-serif;
        font-weight: 600;
        margin-bottom: .3rem;
    }
    .fiche-amendement .meta-fiche {
        font-family: system-ui, sans-serif;
        font-size: .8rem;
        color: var(--gris);
        margin-bottom: .6rem;
        display: flex;
        flex-wrap: wrap;
        gap: .3rem .9rem;
        align-items: center;
    }
    .fiche-amendement .badge {
        display: inline-block;
        font-size: .72rem;
        padding: .1rem .5rem;
        border-radius: 2rem;
    }
    .fiche-amendement .badge.adopte { background: #e3f5e1; color: #18753c; }
    .fiche-amendement .expose {
        font-size: .9rem;
        border-top: 1px dashed var(--bordure);
        padding-top: .6rem;
        margin-top: .4rem;
    }
    .fiche-amendement .expose h3 {
        font-family: system-ui, sans-serif;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--gris);
        margin: 0 0 .3rem;
    }
    .fiche-amendement .liens-fiche {
        font-family: system-ui, sans-serif;
        font-size: .85rem;
        margin-top: .6rem;
    }
    .fiche-amendement .liens-fiche a { margin-right: 1rem; }
{% endblock %}

{% block body %}
    <a class="retour" href="{{ path('loi_index') }}">← Retour à la liste des lois</a>

    <header class="loi">
        <h1>{{ loi.titre ?? loi.id }}</h1>
        <div class="meta">
            {% if loi.origine_publi %}{{ loi.origine_publi }}{% endif %}
            {% if loi.eli %}<a href="{{ loi.eli }}" target="_blank" rel="noopener">Voir sur Légifrance ↗</a>{% endif %}
        </div>
        {% if nbAmendements %}
            <a class="amendements" href="{{ path('loi_amendements', {id: loi.id}) }}">
                Voir les {{ nbAmendements|format_number(locale='fr') }} amendements →
            </a>
        {% elseif nbAmendements is same as(0) %}
            <p class="sans-amendement">Aucun amendement examiné à l'Assemblée nationale pour ce texte
                (adopté conforme — les amendements éventuels ont été déposés au Sénat).</p>
        {% endif %}
    </header>

    {% if loi.visas %}
        <details class="visas">
            <summary>Visas et préambule</summary>
            <div class="contenu">{{ loi.visas|raw }}</div>
        </details>
    {% endif %}

    {% if provenance is not empty %}
        <p class="legende-rayon-x">Rayon X : les passages surlignés proviennent d'amendements
            adoptés à l'Assemblée nationale — cliquez dessus pour voir lesquels, et pourquoi.</p>
    {% endif %}

    {% if articles is empty %}
        <p>Le contenu de cette loi n'est pas disponible dans la base.</p>
    {% else %}
        {% for article in articles %}
            <article class="article" id="article-{{ article.num }}">
                <h2>Article {{ article.num }}</h2>
                <div>{{ article.contenu|raw }}</div>
            </article>
        {% endfor %}
    {% endif %}

    {% if loi.signataires %}
        <section class="signataires">{{ loi.signataires|raw }}</section>
    {% endif %}

    {% if provenance is not empty %}
        <dialog id="modale-amendements">
            <div class="entete">
                <h2>D'où vient ce passage ?</h2>
                <button type="button" aria-label="Fermer" onclick="this.closest('dialog').close()">✕</button>
            </div>
            <div class="corps" id="modale-contenu"></div>
        </dialog>

        <script type="application/json" id="donnees-provenance">{{ provenance|json_encode(constant('JSON_HEX_TAG'))|raw }}</script>
        <script>
            const amendements = JSON.parse(document.getElementById('donnees-provenance').textContent);
            const modale = document.getElementById('modale-amendements');
            const contenu = document.getElementById('modale-contenu');

            document.querySelectorAll('.alinea-amende').forEach((p) => {
                p.title = 'Cliquer pour voir les amendements à l\'origine de ce passage';
                p.addEventListener('click', () => ouvrirModale(p.dataset.amendements.split(',')));
            });

            function ouvrirModale(uids) {
                contenu.replaceChildren();

                // Historique : commission d'abord, puis séance(s), par date de dépôt.
                const fiches = uids.map((uid) => amendements[uid]).filter(Boolean)
                    .sort((a, b) => (a.date || '').localeCompare(b.date || ''));

                for (const a of fiches) {
                    const fiche = document.createElement('article');
                    fiche.className = 'fiche-amendement';

                    const titre = document.createElement('div');
                    titre.className = 'titre-fiche';
                    titre.textContent = `Amendement n° ${a.numero} — ${a.phase}`;
                    fiche.appendChild(titre);

                    const meta = document.createElement('div');
                    meta.className = 'meta-fiche';
                    const badge = document.createElement('span');
                    badge.className = `badge ${a.classe}`;
                    badge.textContent = a.statut;
                    meta.appendChild(badge);
                    for (const info of [
                        a.auteur + (a.groupe ? ` (${a.groupe})` : ''),
                        a.division,
                        a.date ? 'Déposé le ' + a.date.split('-').reverse().join('/') : null,
                    ]) {
                        if (info) {
                            const span = document.createElement('span');
                            span.textContent = info;
                            meta.appendChild(span);
                        }
                    }
                    fiche.appendChild(meta);

                    if (a.expose) {
                        const expose = document.createElement('div');
                        expose.className = 'expose';
                        expose.innerHTML = '<h3>Exposé sommaire</h3>' + a.expose;
                        fiche.appendChild(expose);
                    }

                    const liens = document.createElement('div');
                    liens.className = 'liens-fiche';
                    const lienDetail = document.createElement('a');
                    lienDetail.href = a.url;
                    lienDetail.textContent = 'Détail et débat en séance →';
                    const lienAn = document.createElement('a');
                    lienAn.href = a.urlAn;
                    lienAn.target = '_blank';
                    lienAn.rel = 'noopener';
                    lienAn.textContent = 'Fiche officielle ↗';
                    liens.append(lienDetail, lienAn);
                    fiche.appendChild(liens);

                    contenu.appendChild(fiche);
                }

                modale.showModal();
            }

            modale.addEventListener('click', (e) => {
                if (e.target === modale) modale.close();
            });
        </script>
    {% endif %}
{% endblock %}
