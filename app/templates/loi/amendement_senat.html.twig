{# Le pendant sénatorial de amendement.html.twig : même gabarit, liseré
   bordeaux Sénat, « Objet » au lieu d'« Exposé sommaire » (vocabulaire
   Ameli) et débat retrouvé dans les CRI de séance publique du Sénat. #}
{% extends 'base.html.twig' %}

{% block title %}Amendement n° {{ a.numero }} (Sénat) — {{ loi.num ? 'Loi n° ' ~ loi.num : loi.titre }} — Alinéa{% endblock %}

{% block styles %}
    a.retour {
        font-family: var(--police);
        font-size: .9rem;
        text-decoration: none;
    }
    header.amendement {
        background: #fff;
        border: 1px solid var(--bordure);
        border-top: 4px solid #8b1e3f;
        border-radius: .25rem;
        padding: 1.25rem 2rem;
        margin: 1rem 0 1.5rem;
    }
    header.amendement h1 {
        font-size: 1.3rem;
        margin: 0 0 .3rem;
    }
    header.amendement h1 small {
        font-size: .85rem;
        font-family: var(--police);
        color: #8b1e3f;
        text-transform: uppercase;
        letter-spacing: .05em;
        vertical-align: middle;
        margin-left: .4rem;
    }
    header.amendement .loi-titre {
        font-size: .95rem;
        color: var(--gris);
        margin: 0 0 .75rem;
    }
    header.amendement .meta {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        display: flex;
        flex-wrap: wrap;
        gap: .4rem 1.25rem;
        align-items: center;
    }
    .badge {
        display: inline-block;
        font-family: var(--police);
        font-size: .75rem;
        padding: .15rem .6rem;
        border-radius: 2rem;
        white-space: nowrap;
    }
    .badge.adopte { background: #e3f5e1; color: #18753c; }
    .badge.rejete { background: #fde3e3; color: #ce0500; }
    .badge.irrecevable { background: #fff0e4; color: #b34000; }
    .badge.autre { background: #eee; color: var(--gris); }
    .badge.attente { background: #e8edff; color: var(--bleu); }
    section.bloc {
        background: #fff;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
        padding: 1.25rem 2rem;
        margin-bottom: 1.25rem;
    }
    section.bloc h2 {
        font-family: var(--police);
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #8b1e3f;
        border-bottom: 1px solid var(--bordure);
        padding-bottom: .5rem;
        margin: 0 0 .75rem;
    }
    /* Le HTML d'Ameli embarque polices et tailles inline (Times New Roman
       12pt…) : on les neutralise pour rester dans la charte de la page. */
    .contenu-senat, .contenu-senat * {
        font-family: inherit !important;
        font-size: inherit !important;
    }
    /* Analyse IA : ce que l'amendement change, l'intention réelle et les
       scores ; en alerte quand l'objectif affiché ne colle pas à l'effet réel. */
    section.analyse-ia { border-left: 4px solid #7c6ce0; }
    section.analyse-ia h2 { color: #6a5cd0; border-bottom-color: #e4dfff; }
    section.analyse-ia h2 small {
        text-transform: none;
        letter-spacing: 0;
        font-weight: normal;
        color: var(--gris);
    }
    section.analyse-ia .resume-court {
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0 0 .6rem;
    }
    section.analyse-ia .intention { margin: 0 0 .6rem; }
    section.analyse-ia .intention strong {
        font-family: var(--police);
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #6a5cd0;
    }
    section.analyse-ia .detail {
        margin: 0 0 .6rem;
        color: #3a3a3a;
    }
    section.analyse-ia .scores {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        font-family: var(--police);
    }
    section.analyse-ia .badge-ia {
        font-size: .75rem;
        background: #e9e5ff;
        color: #4a3fa8;
        padding: .12rem .6rem;
        border-radius: 2rem;
    }
    section.analyse-ia.ambigu { border-left-color: #d64d00; }
    section.analyse-ia.ambigu h2 { color: #d64d00; border-bottom-color: #ffe4d4; }
    section.analyse-ia.ambigu .intention {
        background: #ffe4d4;
        border-radius: .25rem;
        padding: .4rem .6rem;
        color: #642700;
    }
    section.analyse-ia.ambigu .intention strong { color: #b23c00; }
    section.analyse-ia .badge-ia.badge-ambigu {
        background: #ffddc7;
        color: #a33c00;
        font-weight: 600;
    }
    section.debat .seance {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        margin-bottom: 1rem;
    }
    .parole { margin-bottom: 1rem; }
    .parole .orateur {
        font-family: var(--police);
        font-size: .85rem;
        font-weight: 600;
        color: #8b1e3f;
    }
    .parole .orateur small { font-weight: normal; color: var(--gris); }
    .parole p { margin: .2rem 0 0; }
    .parole.mention {
        border-left: 3px solid #8b1e3f;
        padding-left: 1rem;
    }
    .parole.didascalie p { font-style: italic; color: var(--gris); }
    p.indisponible {
        font-family: var(--police);
        font-size: .9rem;
        color: var(--gris);
        background: var(--fond);
        border-left: 3px solid var(--bordure);
        padding: .6rem 1rem;
    }
{% endblock %}

{% block body %}
    <a class="retour" href="{{ path('loi_amendements', {id: loi.id}) }}">← Retour aux amendements de la loi</a>

    <header class="amendement">
        <h1>Amendement n° {{ a.numero }} <small>Sénat</small></h1>
        <p class="loi-titre">{{ loi.titre ?? loi.id }}</p>
        <div class="meta">
            <span class="badge {{ a.sort_classe }}">{{ a.statut }}</span>
            <span>{{ a.auteur }}{% if a.groupe %} ({{ a.groupe }}){% endif %}</span>
            {% if a.division %}<span>{{ a.division }}</span>{% endif %}
            {% if a.date_depot %}<span>Déposé le {{ a.date_depot|date('d/m/Y') }}</span>{% endif %}
            <span>{{ a.phase == 'Sénat (commission)' ? 'Commission' : 'Séance publique' }}</span>
            <a href="{{ a.url_senat }}" target="_blank" rel="noopener">Fiche officielle ↗</a>
        </div>
    </header>

    {% if a.dispositif %}
        <section class="bloc">
            <h2>Dispositif</h2>
            <div class="contenu-senat">{{ a.dispositif|raw }}</div>
        </section>
    {% endif %}

    {% if analyse %}
        {% set libellesCategorie = {
            coordination: 'Coordination', redactionnel: 'Rédactionnel',
            simplification: 'Simplification', correction: 'Correction',
            precision: 'Précision', consequence: 'Conséquence',
            coherence: 'Cohérence', fond: 'Fond',
        } %}
        {% set ambigu = analyse.ambiguite is not null and analyse.ambiguite >= 50 %}
        <section class="bloc analyse-ia{{ ambigu ? ' ambigu' }}">
            <h2>{{ ambigu ? '⚠ Ce que ça change vraiment' : 'Ce que ça change' }} <small>· analyse IA</small></h2>
            {% if analyse.resume %}
                <p class="resume-court">{{ analyse.resume }}</p>
            {% else %}
                <p class="resume-court vide">Amendement technique, sans changement de fond.</p>
            {% endif %}
            {% if analyse.intention %}
                <p class="intention"><strong>Intention :</strong> {{ analyse.intention }}</p>
            {% endif %}
            {% if analyse.resume_detaille %}
                <p class="detail">{{ analyse.resume_detaille }}</p>
            {% endif %}
            <div class="scores">
                {% if analyse.categorie %}
                    <span class="badge-ia">{{ libellesCategorie[analyse.categorie] ?? analyse.categorie }}</span>
                {% endif %}
                {% if analyse.score_impact is not null %}
                    <span class="badge-ia" title="Poids du changement sur la portée et l'intention de la loi">Impact {{ analyse.score_impact }}/100</span>
                {% endif %}
                {% if analyse.ambiguite is not null %}
                    <span class="badge-ia{{ ambigu ? ' badge-ambigu' }}" title="Écart entre l'objectif affiché par l'auteur et l'effet réel du changement">Ambiguïté {{ analyse.ambiguite }}/100</span>
                {% endif %}
            </div>
        </section>
    {% endif %}

    {% if a.expose_sommaire %}
        <section class="bloc">
            <h2>Objet</h2>
            <div class="contenu-senat">{{ a.expose_sommaire|raw }}</div>
        </section>
    {% endif %}

    <section class="bloc debat">
        <h2>Le débat en séance publique (compte rendu)</h2>
        {% if debat %}
            <p class="seance">
                Séance du {{ debat.compte_rendu.date_seance|date('d/m/Y') }}
                — {{ debat.paroles|length }} intervention{{ debat.paroles|length > 1 ? 's' }}
                · <a href="{{ debat.compte_rendu.url_page }}" target="_blank" rel="noopener">Compte rendu intégral ↗</a>
            </p>
            {% for parole in debat.paroles %}
                <div class="parole{{ parole.mentionne ? ' mention' }}{{ parole.orateur_nom is null ? ' didascalie' }}">
                    {% if parole.orateur_nom %}
                        <div class="orateur">{{ parole.orateur_nom }}{% if parole.orateur_qualite %} <small>{{ parole.orateur_qualite }}</small>{% endif %}</div>
                    {% endif %}
                    <p>{{ parole.texte_brut|nl2br }}</p>
                </div>
            {% endfor %}
        {% elseif a.phase == 'Sénat (commission)' %}
            <p class="indisponible">Amendement examiné en commission : les comptes rendus des
                réunions de commission du Sénat ne sont pas importés, seuls ceux de la séance
                publique le sont. Le détail vit sur la fiche officielle senat.fr.</p>
        {% else %}
            <p class="indisponible">Cet amendement n'apparaît pas nommément dans les comptes
                rendus de séance importés (non soutenu, retiré avant discussion, traité en
                groupe — ou séance pas encore importée via app:import:comptes-rendus-senat).</p>
        {% endif %}
    </section>
{% endblock %}
