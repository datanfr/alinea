{% extends 'base.html.twig' %}

{% block title %}Alinéa — Les lois{% endblock %}

{% block styles %}
    form.recherche {
        display: flex;
        gap: .5rem;
        margin-bottom: 1.5rem;
        font-family: var(--police);
    }
    form.recherche input[type="search"] {
        flex: 1;
        padding: .65rem .9rem;
        font-size: 1rem;
        border: 1px solid var(--bordure);
        border-radius: .25rem;
    }
    form.recherche button {
        padding: .65rem 1.4rem;
        font-size: 1rem;
        color: #fff;
        background: var(--bleu);
        border: none;
        border-radius: .25rem;
        cursor: pointer;
    }
    form.recherche button:hover { background: var(--bleu-hover); }
    label.filtre-vigueur {
        display: flex;
        align-items: center;
        gap: .45rem;
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        margin: -0.75rem 0 1rem;
        cursor: pointer;
    }
    ul.lois li.hors-vigueur { border-left-color: #b1b1b1; }
    ul.lois li.hors-vigueur a { color: var(--gris); }
    ul.lois .badge-vigueur {
        font-size: .72rem;
        padding: .05rem .5rem;
        border-radius: 2rem;
        background: #eee;
        color: #5d5d5d;
        white-space: nowrap;
    }
    p.compteur {
        font-family: var(--police);
        font-size: .85rem;
        color: var(--gris);
        margin: 0 0 1rem;
    }
    ul.lois {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    ul.lois li {
        background: #fff;
        border: 1px solid var(--bordure);
        border-left: 4px solid var(--bleu);
        border-radius: .25rem;
        margin-bottom: .75rem;
    }
    ul.lois a {
        display: block;
        padding: .9rem 1.2rem;
        text-decoration: none;
        color: var(--encre);
    }
    ul.lois a:hover { background: #f0f0ff; }
    ul.lois .meta {
        font-family: var(--police);
        font-size: .8rem;
        color: var(--bleu);
        display: flex;
        gap: 1rem;
        margin-bottom: .2rem;
    }
    nav.pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        margin: 2rem 0;
        font-family: var(--police);
    }
{% endblock %}

{% block body %}
    <h1>Les lois publiées au Journal officiel</h1>

    <form class="recherche" action="{{ path('loi_index') }}" method="get">
        <input type="search" name="q" value="{{ query }}" placeholder="Rechercher une loi (ex. : narcotrafic, sécurité, environnement…)" aria-label="Rechercher une loi">
        {% if horsVigueur %}<input type="hidden" name="hors_vigueur" value="1">{% endif %}
        <button type="submit">Rechercher</button>
    </form>

    <form action="{{ path('loi_index') }}" method="get">
        {% if query %}<input type="hidden" name="q" value="{{ query }}">{% endif %}
        <label class="filtre-vigueur">
            <input type="checkbox" name="hors_vigueur" value="1" {{ horsVigueur ? 'checked' }} onchange="this.form.submit()">
            Inclure les lois qui ne sont plus (ou pas encore) en vigueur — abrogées, périmées, entrée en vigueur différée
        </label>
    </form>

    <p class="compteur">
        {{ total }} loi{{ total > 1 ? 's' }}
        {%- if not horsVigueur %} en vigueur{% endif %}
        {%- if query %} pour « {{ query }} »{% endif %}
    </p>

    {% if lois is empty %}
        <p>Aucune loi ne correspond à cette recherche.</p>
    {% else %}
        <ul class="lois">
            {% for loi in lois %}
                <li{% if loi.etat_libelle %} class="hors-vigueur"{% endif %}>
                    <a href="{{ path('loi_show', {id: loi.id}) }}">
                        <div class="meta">
                            {% if loi.num %}<span>Loi n° {{ loi.num }}</span>{% endif %}
                            {% if loi.date_fr %}<span>{{ loi.date_fr }}</span>{% endif %}
                            {% if loi.etat_libelle %}<span class="badge-vigueur">{{ loi.etat_libelle }}</span>{% endif %}
                        </div>
                        {{ loi.titre ?? loi.id }}
                    </a>
                </li>
            {% endfor %}
        </ul>

        {% if pages > 1 %}
            <nav class="pagination">
                {% set paginationParams = horsVigueur ? {q: query, hors_vigueur: 1} : {q: query} %}
                {% if page > 1 %}
                    <a href="{{ path('loi_index', paginationParams|merge({page: page - 1})) }}">← Précédent</a>
                {% endif %}
                <span>Page {{ page }} / {{ pages }}</span>
                {% if page < pages %}
                    <a href="{{ path('loi_index', paginationParams|merge({page: page + 1})) }}">Suivant →</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
